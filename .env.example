# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── MikroTik Router (RB5009) ─────────────────────────────────────────────────
ROUTER_HOST=192.168.4.1
ROUTER_USER=admin
ROUTER_PASS=your_router_password
# ROUTER_VERIFY_SSL=false   # MikroTik uses a self-signed cert; leave false

# ── MikroTik Switch (CRS310) ─────────────────────────────────────────────────
SWITCH_HOST=192.168.4.2     # Set to the switch management IP
SWITCH_USER=admin
SWITCH_PASS=your_switch_password
# SWITCH_VERIFY_SSL=false

# ── App server ────────────────────────────────────────────────────────────────
# APP_HOST=0.0.0.0
# APP_PORT=8000
